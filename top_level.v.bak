`timescale 1ns / 1ps

module top_level (
    input  wire clk_50m,     // Системна частота ПЛІС (50 МГц з кварцу)
    input  wire rst_btn,     // Кнопка ресету (якщо є)
    input  wire spi_clk,     // Пін від STM32: SCK
    input  wire spi_mosi,    // Пін від STM32: MOSI
    input  wire spi_cs,      // Пін від STM32: CS
    output wire spi_miso,    // Пін до STM32: MISO
    output wire [7:0] led    // 8 пінів, підключених до світлодіодів
);

    // Створюємо екземпляр нашого модуля SPI (ніби запаюємо його на плату)
    SPI my_spi_slave (
        .clk(clk_50m),
        .rst(rst_btn),        // Увага: якщо кнопки немає, напиши тут 1'b1, щоб він не висів у ресеті!
        .CLK(spi_clk),
        .MOSI(spi_mosi),
        .CS(spi_cs),
        .MISO(spi_miso),
        .data_rx(led),        // НАПРЯМУ підключаємо прийнятий байт до світлодіодів!
        .rx_done(),           // Цей прапорець нам поки не потрібен для діодів (висить у повітрі)
        .data_tx(8'hCA)       // Для тесту MISO нехай завжди відправляє 0xCA (11001010)
    );

endmodule